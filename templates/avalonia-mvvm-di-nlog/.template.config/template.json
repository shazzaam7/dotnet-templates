{
  "$schema": "http://json.schemastore.org/template",
  "author": "Shazzaam",
  "classifications": [
    "Desktop",
    "Xaml",
    "Avalonia",
    "MVVM",
    "DI",
    "Windows",
    "Linux"
  ],
  "description": "A cross-platform Avalonia UI Application using MVVM pattern with built-in Dependency Injection",
  "groupIdentity": "Shazzaam.Avalonia.MVVM.DI",
  "identity": "Shazzaam.Avalonia.MVVM.DI",
  "name": "Avalonia MVVM App with Dependency Injection, custom NLog Logger and Localization",
  "shortName": "avalonia-mvvm-di-nlog",
  "sourceName": "MyCustomTemplate",
  "defaultName": "AvaloniaApp",
  "preferNameDirectory": true,
  "type": "project",
  "tags": {
    "language": "C#"
  },
  "symbols": {
    "IncludeNLog": {
      "type": "parameter",
      "description": "Include NLog logging infrastructure in the Core project.",
      "datatype": "bool",
      "displayName": "Include NLog Logger",
      "defaultValue": "true"
    },
    "skipRestore": {
      "type": "parameter",
      "datatype": "bool",
      "description": "If specified, skips the automatic restore of the project on create.",
      "defaultValue": "false"
    },
    "HostIdentifier": {
      "type": "bind",
      "binding": "HostIdentifier"
    }
  },
  "sources": [
    {
      "source": "./",
      "target": "./",
      "modifiers": [
        {
          "condition": "(!IncludeNLog)",
          "exclude": ["**/Logger/**", "**/nlog.config"]
        }
      ]
    },
    {
      "source": "./scripts",
      "target": "./scripts"
    },
    {
      "source": "./.github",
      "target": "./.github"
    },
    {
      "source": "./docs",
      "target": "./docs"
    }
  ],
  "primaryOutputs": [
    { "path": "MyCustomTemplate.sln" },
    {
      "condition": "(HostIdentifier != \"dotnetcli\" && HostIdentifier != \"dotnetcli-preview\")",
      "path": "source/MyCustomTemplate/Views/MainWindow.axaml"
    },
    {
      "condition": "(HostIdentifier != \"dotnetcli\" && HostIdentifier != \"dotnetcli-preview\")",
      "path": "source/MyCustomTemplate/ViewModels/MainWindowViewModel.cs"
    }
  ],
  "postActions": [
    {
      "id": "restore",
      "condition": "(!skipRestore)",
      "description": "Restore NuGet packages required by this project.",
      "manualInstructions": [{ "text": "Run 'dotnet restore'" }],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    },
    {
      "id": "editor",
      "condition": "(HostIdentifier != \"dotnetcli\" && HostIdentifier != \"dotnetcli-preview\")",
      "description": "Opens MainWindow and MainWindowViewModel in the editor",
      "manualInstructions": [],
      "actionId": "84C0DA21-51C8-4541-9940-6CA19AF04EE6",
      "args": {
        "files": "1;2"
      },
      "continueOnError": true
    }
  ]
}
